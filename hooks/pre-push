#!/bin/bash
# Verifies certain criteria before pushing.

set -u

messages=()
while read -r _ local_oid _ remote_oid; do
  range="${remote_oid}..${local_oid}"
  while read -r filename; do
    echo "examining: ${filename}"
    at_ver=''
    lib_ver=''

    case ${filename} in
      *.js)
        at_ver=$(git diff "${range}" "${filename}" |
          awk '/^\+\/\/ @version/ {print $NF}')

        [[ -z ${at_ver} ]] && messages+=("${filename} needs a @version bump.")
        ;;
      *) ;;
    esac

    case ${filename} in
      *.user.js) ;;
      *.js)
        lib_ver=$(git diff "${range}" "${filename}" |
          awk '/^\+  const version = / {
                      sub(/;/, "")
                      print $NF
                    }')
        if [[ -z ${lib_ver} ]]; then
          messages+=("${filename} needs an internal version update.")
        fi
        if [[ "${at_ver}" != "${lib_ver}" ]]; then
          messages+=("${filename} versions do not match: ${at_ver} ${lib_ver}")
        fi
        ;;
      *) ;;
    esac

  done < <(git diff --name-only "${range}")

  cnt=${#messages[*]}

  if ((cnt)); then
    echo "Issues found (${cnt}):"
    for msg in "${messages[@]}"; do
      echo "${msg}"
    done
    exit 1
  fi
done
